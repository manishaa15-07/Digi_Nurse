# ============================================================
# DigiNurse Frontend — Environment Variables Example
# ============================================================
# Copy this file to .env and fill in your values.
# .env is gitignored; this file is safe to commit.
#
# EXPO_PUBLIC_* prefix required for Expo client-side access.
# ============================================================

# Override API URL (leave blank to use deployed Render backend)
# iOS Simulator:
#   EXPO_PUBLIC_API_URL=http://localhost:5000
# Android Emulator:
#   EXPO_PUBLIC_API_URL=http://10.0.2.2:5000
# Real Device (use your machine's LAN IP):
#   EXPO_PUBLIC_API_URL=http://192.168.x.x:5000
EXPO_PUBLIC_API_URL=https://digi-nurse.onrender.com
